{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "baseUrl": "./src/main/resources/static/typescript",
    "rootDir": "./src/main/resources/static/typescript",
    "outDir": "./src/main/resources/static/javascript",
    "removeComments": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "files": [
    "src/main/resources/static/typescript/application/paginas/editor/grade.ts",
    "src/main/resources/static/typescript/infrastructure/bindings.ts"
  ],
  "exclude": [
    "build"
  ]
}
